# ─── Backend (tiba-api) ───────────────────────────────────────────────────────

# Server
SERVER_PORT=8080
ENV=production              # development | production

# Database (PostgreSQL)
DB_HOST=<VPS_IP>            # IP or hostname of the PostgreSQL container/server
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=<strong_password>
DB_NAME=tiba_db
DB_SSLMODE=disable          # enable on managed DB services

# JWT
JWT_SECRET=<long_random_secret>   # openssl rand -hex 32
JWT_ACCESS_EXPIRY=8h
JWT_REFRESH_EXPIRY=720h

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760      # bytes (default 10 MB)

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://<VPS_IP>:3000

# SMTP (Gmail App Password — https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=myverse2023@gmail.com
SMTP_PASSWORD=<gmail_app_password>

# Public API URL used in email links / callbacks
API_URL=http://<VPS_IP>:8080


# ─── Frontend (tiba-frontend) ─────────────────────────────────────────────────

# Must match the public IP/domain of the backend container
NEXT_PUBLIC_API_URL=http://<VPS_IP>:8080/api/v1
